# VeriNews — Environment Variables
# Copy this file to .env and fill in the values.
# The .env file should NEVER be committed to version control.

# Flask secret key (use a long random string in production)
SECRET_KEY=verinews-dev-secret-change-me

# ── Firebase Frontend Config (paste from Firebase Console) ────────────────────
# console.firebase.google.com → Project Settings → Your apps → Web → Config
FIREBASE_API_KEY=your-api-key-here
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# ── Firebase Service Account ──────────────────────────────────────────────────
# Download firebase_service_account.json from:
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Place the file at: c:\Users\vaibh\Documents\Verinews\firebase_service_account.json
